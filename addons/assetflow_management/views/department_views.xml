<odoo>
    <record id="view_assetflow_department_tree" model="ir.ui.view">
        <field name="name">assetflow.department.tree</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="manager_id"/>
                <field name="employee_ids"/>
                <field name="asset_ids"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_department_form" model="ir.ui.view">
        <field name="name">assetflow.department.form</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="manager_id"/>
                    </group>
                    <notebook>
                        <page string="Employees">
                            <field name="employee_ids"/>
                        </page>
                        <page string="Assets">
                            <field name="asset_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_assetflow_departments" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">assetflow.department</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
