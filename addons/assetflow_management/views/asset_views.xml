<odoo>
    <record id="view_assetflow_asset_tree" model="ir.ui.view">
        <field name="name">assetflow.asset.tree</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'available'" decoration-warning="state == 'allocated'" decoration-danger="state == 'maintenance'">
                <field name="name"/>
                <field name="asset_tag"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="assigned_to"/>
                <field name="location"/>
                <field name="value"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_asset_kanban" model="ir.ui.view">
        <field name="name">assetflow.asset.kanban</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <field name="name"/>
                <field name="asset_tag"/>
                <field name="state"/>
                <field name="category_id"/>
                <field name="value"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div>Tag: <field name="asset_tag"/></div>
                            <div>Category: <field name="category_id"/></div>
                            <div>Value: <field name="value"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_assetflow_asset_form" model="ir.ui.view">
        <field name="name">assetflow.asset.form</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <button name="action_allocate" string="Allocate" type="object" class="btn-primary" attrs="{'invisible':[('state','!=','available')]}"/>
                    <button name="action_return" string="Return" type="object" class="btn-secondary" attrs="{'invisible':[('state','!=','allocated')]}"/>
                    <button name="action_send_to_maintenance" string="Send to Maintenance" type="object" class="btn-warning" attrs="{'invisible':[('state','in',('maintenance','retired'))]}"/>
                    <button name="action_complete_maintenance" string="Complete Maintenance" type="object" class="btn-success" attrs="{'invisible':[('state','!=','maintenance')]}"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_allocations" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="allocation_ids" widget="statinfo" string="Allocations"/>
                        </button>
                        <button name="action_view_maintenance" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_ids" widget="statinfo" string="Maintenance"/>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="asset_tag"/>
                        <field name="serial_number"/>
                        <field name="category_id"/>
                        <field name="department_id"/>
                        <field name="assigned_to"/>
                        <field name="purchase_date"/>
                        <field name="warranty_end"/>
                        <field name="value"/>
                        <field name="location"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_assetflow_asset_search" model="ir.ui.view">
        <field name="name">assetflow.asset.search</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_tag"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <field name="assigned_to"/>
                <filter string="Available" name="available" domain="[('state','=','available')]"/>
                <filter string="Allocated" name="allocated" domain="[('state','=','allocated')]"/>
                <filter string="Maintenance" name="maintenance" domain="[('state','=','maintenance')]"/>
                <group expand="1" string="Group By">
                    <filter string="Category" name="group_by_category" context="{'group_by':'category_id'}"/>
                    <filter string="Department" name="group_by_department" context="{'group_by':'department_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_assetflow_assets" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_assetflow_asset_search"/>
    </record>
</odoo>
