<odoo>
    <record id="view_assetflow_employee_tree" model="ir.ui.view">
        <field name="name">assetflow.employee.tree</field>
        <field name="model">assetflow.employee</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="employee_code"/>
                <field name="department_id"/>
                <field name="job_title"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_employee_form" model="ir.ui.view">
        <field name="name">assetflow.employee.form</field>
        <field name="model">assetflow.employee</field>
        <field name="arch" type="xml">
            <form string="Employee">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="employee_code"/>
                        <field name="department_id"/>
                        <field name="managed_department_id"/>
                        <field name="job_title"/>
                        <field name="email"/>
                        <field name="phone"/>
                    </group>
                    <notebook>
                        <page string="Requests">
                            <field name="asset_request_ids"/>
                        </page>
                        <page string="Allocations">
                            <field name="allocation_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_assetflow_employees" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">assetflow.employee</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
