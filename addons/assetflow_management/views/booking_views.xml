<odoo>
    <record id="view_assetflow_booking_tree" model="ir.ui.view">
        <field name="name">assetflow.resource.booking.tree</field>
        <field name="model">assetflow.resource.booking</field>
        <field name="arch" type="xml">
            <tree>
                <field name="resource_type"/>
                <field name="resource_name"/>
                <field name="employee_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_booking_form" model="ir.ui.view">
        <field name="name">assetflow.resource.booking.form</field>
        <field name="model">assetflow.resource.booking</field>
        <field name="arch" type="xml">
            <form string="Resource Booking">
                <sheet>
                    <group>
                        <field name="resource_type"/>
                        <field name="resource_name"/>
                        <field name="employee_id"/>
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                        <field name="state"/>
                        <field name="purpose"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_assetflow_bookings" model="ir.actions.act_window">
        <field name="name">Resource Bookings</field>
        <field name="res_model">assetflow.resource.booking</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
